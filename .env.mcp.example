# MCP Server Environment Variables
# Copy to .env.mcp and fill in real values.
# NEVER commit .env.mcp to git — it is in .gitignore.
# Inject into Claude Code via OS environment or a secrets manager.

# ── Notion MCP ───────────────────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# Grant access to: UTUBooking Content Calendar, SEO Keyword Database, Post Status Board
NOTION_API_KEY=secret_YOUR_NOTION_INTEGRATION_TOKEN

# ── Slack MCP ─────────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps
# Required OAuth scopes: channels:read, chat:write, files:write
# Install to workspace and copy Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-YOUR-SLACK-BOT-TOKEN
SLACK_TEAM_ID=T0XXXXXXXXX   # Found in Slack workspace URL: app.slack.com/client/T0XXXXXXXXX

# ── Google Drive MCP ──────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Enable: Google Drive API
# Scopes: https://www.googleapis.com/auth/drive.file
GDRIVE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GDRIVE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN   # Obtain via OAuth flow

# ── GitHub MCP ────────────────────────────────────────────────────────────────
# Create a Personal Access Token (classic) at https://github.com/settings/tokens
# Required scopes: repo (full), read:org
# Repo: Gamil17/UTUBooking
GITHUB_TOKEN=ghp_YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# ── GA4 MCP (Video 20 — SEO Command Center) ──────────────────────────────────
# Create a service account at https://console.cloud.google.com
# Enable: Google Analytics Data API
# Download JSON key file → set path below
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID           # Found in GA4: Admin → Property Settings
GOOGLE_APPLICATION_CREDENTIALS=./credentials/ga4-service-account.json

# ── Google Search Console MCP (Video 20) ─────────────────────────────────────
# Reuse OAuth credentials from GDrive setup (same Google account)
# Additional scope needed: https://www.googleapis.com/auth/webmasters.readonly
GSC_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GSC_CLIENT_SECRET=YOUR_CLIENT_SECRET
GSC_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_WITH_GSC_SCOPE
# GSC_SITE_URL is hardcoded in settings.json: https://utubooking.com

# ── DataForSEO MCP (Video 21 — Keyword Research) ─────────────────────────────
# Create account at https://dataforseo.com
# Free trial: 2,500 API tasks
# Pricing: pay-per-use; keyword research ~$0.001-0.05 per query
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=YOUR_DATAFORSEO_PASSWORD

# ── HubSpot MCP (Month 2) ─────────────────────────────────────────────────────
# Not configured yet — add in Month 2 when CTA lead tracking is needed.
# When ready: https://developers.hubspot.com/docs/api/private-apps
# HUBSPOT_ACCESS_TOKEN=YOUR_HUBSPOT_PRIVATE_APP_TOKEN

# ── Notion Database IDs ───────────────────────────────────────────────────────
# After connecting Notion MCP, find these IDs in each database URL:
# notion.so/WORKSPACE/DATABASE_ID?v=VIEW_ID
NOTION_DB_CONTENT_CALENDAR=     # UTUBooking SEO Content Calendar database ID
NOTION_DB_KEYWORD_LIST=         # UTUBooking Keyword Database ID
NOTION_DB_POST_STATUS=          # Post Review Status board ID
