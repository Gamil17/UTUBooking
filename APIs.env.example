# UTUBooking API Keys — Copy to APIs.env and fill in values
# APIs.env is gitignored — never commit real keys

# OpenRouter — required for Crosscheck (GPT/Gemini) and AI image generation
# Get key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Image generation model (via OpenRouter)
IMAGE_MODEL=google/gemini-2.0-flash-exp:free
IMAGE_SIZE=600x338

# --- Other keys (keep in .env.mcp for MCP servers, not here) ---
# See .env.mcp.example for GA4, GSC, DataForSEO, Notion, Slack tokens
