{
  "title": "UTUBooking — Infrastructure",
  "uid": "utu-infra",
  "tags": ["utubooking", "infrastructure", "aws"],
  "timezone": "Asia/Riyadh",
  "refresh": "60s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "ALB 5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(aws_alb_httpcode_elb_5xx_count_sum[5m])",
          "legendFormat": "ALB 5xx/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(aws_alb_httpcode_target_5xx_count_sum[5m])",
          "legendFormat": "Target 5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      }
    },
    {
      "id": 2,
      "title": "CloudFront Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "aws_cloudfront_cache_hit_rate_average",
          "legendFormat": "Cache hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "ECS CPU Utilization per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "aws_ecs_service_cpuutilization_average",
          "legendFormat": "{{service_name}} CPU%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "ECS Memory Utilization per Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "aws_ecs_service_memory_utilization_average",
          "legendFormat": "{{service_name}} Mem%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "RDS Replication Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "aws_rds_replica_lag_average",
          "legendFormat": "{{dbinstance_identifier}} lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Last Backup Time",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "(time() - backup_last_success_timestamp) / 3600",
          "legendFormat": "Hours since last backup"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "displayName": "Hours Since Last Backup",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 20, "color": "yellow" },
              { "value": 25, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
