{
  "title": "UTUBooking — Redis Cluster",
  "uid": "utu-redis",
  "tags": ["utubooking", "redis"],
  "timezone": "Asia/Riyadh",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Memory Used / Max per Shard",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "redis_memory_used_bytes / redis_config_maxmemory * 100",
          "legendFormat": "{{instance}} memory %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 85, "color": "yellow" },
              { "value": 95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "{{instance}} hit ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Evictions per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(redis_evicted_keys_total[1m])",
          "legendFormat": "{{instance}} evictions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Cluster Slot Coverage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "redis_cluster_slots_assigned",
          "legendFormat": "Slots assigned"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Cluster Slots (should be 16384)",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 16384, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "redis_connected_clients",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Commands Processed per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "{{instance}} cmd/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ]
}
