{
  "title": "UTUBooking — Hajj Peak Traffic",
  "uid": "utu-hajj-peak",
  "tags": ["utubooking", "hajj", "peak"],
  "timezone": "Asia/Riyadh",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Hotel Search RPS (target: 500 req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"hotel\"}[1m]))",
          "legendFormat": "Hotel search RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 400, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Booking Funnel — Conversion (searches → bookings)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"hotel\",path=~\".*/search.*\"}[5m]))",
          "legendFormat": "Hotel searches/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"booking\",method=\"POST\"}[5m]))",
          "legendFormat": "New bookings/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"payment\",status_code=\"200\"}[5m]))",
          "legendFormat": "Successful payments/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "ECS Task Count During Peak",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "aws_ecs_service_running_task_count",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 2, "color": "green" },
              { "value": 15, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "P95 Response Time — Hotel Search",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"hotel\"}[5m])) by (le)) * 1000",
          "legendFormat": "Hotel P95 ms"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"hotel\"}[5m])) by (le)) * 1000",
          "legendFormat": "Hotel P99 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 300, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Redis Cache Hit Rate During Peak",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "displayName": "Redis Hit Ratio (target >60%)"
        }
      }
    },
    {
      "id": 6,
      "title": "Active Concurrent Users (estimate)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count[2m])) * 120",
          "legendFormat": "Concurrent users (2min window)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Est. Concurrent Users",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 80000, "color": "yellow" },
              { "value": 100000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Error Rate During Peak (target <1%)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 * sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "displayName": "Error Rate %",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
