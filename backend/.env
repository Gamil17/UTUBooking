# ══════════════════════════════════════════════════════════════════════════════
# UTUBooking — root .env (used by all microservices in development)
# NEVER commit real secrets. Copy to each service's directory as needed.
# ══════════════════════════════════════════════════════════════════════════════

# ── Shared infrastructure ──────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
REDIS_URL=redis://localhost:6379

# ── Phase 4 DB Sharding — Shard endpoints (from CloudFormation 12-db-sharding.yml) ──
# In dev: dummy values. In AWS: inject from SSM Parameter Store via ECS TaskDefinition.
# Format: postgresql://user:pass@rds-endpoint:5432/dbname
DB_URL_KSA=postgres://utu_user:password@ksa-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_KSA=postgres://utu_user:password@ksa-read-replica.rds.amazonaws.com:5432/utu_booking
DB_URL_UAE=postgres://utu_user:password@uae-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_UAE=postgres://utu_user:password@uae-read-replica.rds.amazonaws.com:5432/utu_booking
DB_URL_KWT=postgres://utu_user:password@kwt-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_KWT=postgres://utu_user:password@kwt-read-replica.rds.amazonaws.com:5432/utu_booking
DB_URL_JOR=postgres://utu_user:password@jor-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_JOR=postgres://utu_user:password@jor-read-replica.rds.amazonaws.com:5432/utu_booking
DB_URL_MAR=postgres://utu_user:password@mar-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_MAR=postgres://utu_user:password@mar-read-replica.rds.amazonaws.com:5432/utu_booking
DB_URL_TUN=postgres://utu_user:password@tun-primary.rds.amazonaws.com:5432/utu_booking
READ_DB_URL_TUN=postgres://utu_user:password@tun-read-replica.rds.amazonaws.com:5432/utu_booking

# ── Phase 5 DB Sharding — Turkey (EU region for KVKK compliance) ──
# KVKK (Turkish Data Protection Act) requires personal data of Turkish residents to be stored in Turkey/EU
# Using AWS eu-south-1 (Milan) or eu-central-1 (Frankfurt) until AWS Istanbul region becomes available
DB_URL_ISTANBUL=postgres://utu_user:password@istanbul-primary.rds.eu-south-1.amazonaws.com:5432/utu_booking
READ_DB_URL_ISTANBUL=postgres://utu_user:password@istanbul-read-replica.rds.eu-south-1.amazonaws.com:5432/utu_booking

# ── Auth service ───────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-minimum-32-chars
JWT_REFRESH_SECRET=another-completely-different-secret-minimum-32-chars
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# ── STC Pay Merchant API v2 ────────────────────────────────────────────────────
# Auth: API key + HMAC-SHA256 per-request signature (NOT OAuth2)
# Docs: backend/docs/stcpay-api.md  |  https://dev.stcpay.net
STCPAY_BASE_URL=https://b2b.stcpay.com.sa/b2b/payment
STCPAY_API_KEY=your_stcpay_api_key
STCPAY_API_SECRET=your_stcpay_api_secret
STCPAY_MERCHANT_ID=TEST_your_merchant_id
STCPAY_SANDBOX_MODE=true
STCPAY_WEBHOOK_SECRET=your_stcpay_webhook_hmac_secret
STCPAY_CALLBACK_URL=https://api.utubooking.com/api/payments/webhook

# ── Moyasar (Mada debit card) ──────────────────────────────────────────────────
# Docs: https://docs.moyasar.com
MOYASAR_API_KEY=sk_test_your_moyasar_key
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret
MOYASAR_CALLBACK_URL=https://api.utubooking.com/api/payments/mada/callback

# ── Stripe (Visa / Mastercard — international) ─────────────────────────────────
# Docs: https://stripe.com/docs/api
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Phase 5+ Payment Gateways ───────────────────────────────────────────────────
# All start with SANDBOX credentials — swap to production after testing

# Turkey — iyzico (https://www.iyzipay.com/)
# Sandbox: https://sandbox-api.iyzipay.com
# Dashboard: https://sandbox-merchant.iyzipay.com
IYZICO_API_KEY=sandbox_xxx
IYZICO_SECRET_KEY=sandbox_xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_URL=https://api.utubooking.com/api/v1/payment/webhook/iyzico

# Indonesia — Midtrans (https://midtrans.com/)
# Sandbox: https://app.sandbox.midtrans.com
# API Docs: https://docs.midtrans.com/
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_ENV=sandbox
MIDTRANS_WEBHOOK_URL=https://api.utubooking.com/api/v1/payment/webhook/midtrans

# Malaysia — iPay88 (https://www.ipay88.com/)
# Sandbox: https://sandbox.ipay88.com.my
# Merchant Portal: https://sandbox.ipay88.com.my/ePayment/Login.aspx
IPAY88_MERCHANT_CODE=xxx
IPAY88_MERCHANT_KEY=xxx
IPAY88_BASE_URL=https://sandbox.ipay88.com.my
IPAY88_WEBHOOK_URL=https://api.utubooking.com/api/v1/payment/webhook/ipay88

# Phase 6 (Planned) — Razorpay & JazzCash
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_URL=https://api.utubooking.com/api/v1/payment/webhook/razorpay
# JAZZCASH_MERCHANT_ID=xxx
# JAZZCASH_PASSWORD=xxx
# JAZZCASH_WEBHOOK_URL=https://api.utubooking.com/api/v1/payment/webhook/jazzcash

# ── Hotelbeds (hotel search) ───────────────────────────────────────────────────
# Docs: https://developer.hotelbeds.com
# Signature: SHA256(ApiKey + Secret + UnixTimestampSeconds)
HOTELBEDS_API_KEY=your_hotelbeds_api_key
HOTELBEDS_SECRET=your_hotelbeds_secret
HOTELBEDS_BASE_URL=https://api.hotelbeds.com/hotel-api/1.0
HOTELBEDS_CAR_BASE_URL=https://api.hotelbeds.com/car-rental-api/1.0

# ── Booking.com Demand API (European hotel inventory — Phase 5) ───────────────
# Apply at: https://developers.booking.com
# Approval time: 2–4 weeks
# After approval, set BOOKINGCOM_ENV=production. Until then, test stays in sandbox.
BOOKINGCOM_USERNAME=CHANGE_ME   # affiliate_id from Partner Centre
BOOKINGCOM_PASSWORD=CHANGE_ME   # api_key from Partner Centre
BOOKINGCOM_ENV=test             # change to 'production' at launch

# ── Amadeus (flight search — primary GDS) ─────────────────────────────────────
# Docs: https://developers.amadeus.com
# hostname: 'test' for sandbox, 'production' for live
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test

# ── CarTrawler (car rental search + booking) ──────────────────────────────────
# Docs: https://docs.cartrawler.com/ota/
# Auth: OTA XML POS element — RequestorID Type="16"
# Sandbox: https://ota.cartrawler.com/cartrawlerota/s/xml
# Production: https://api.cartrawler.com/cartrawlerota/s/xml
CARTRAWLER_CLIENT_ID=your_cartrawler_client_id
CARTRAWLER_PASSWORD=your_cartrawler_password
CARTRAWLER_BASE_URL=https://ota.cartrawler.com/cartrawlerota/s/xml
CARTRAWLER_RESIDENT_COUNTRY=SA

# ── Sabre (flight search — fallback GDS) ──────────────────────────────────────
# Docs: https://developer.sabre.com
# SABRE_CLIENT_ID format: 'V1:<username>:<password>:<domain>'
SABRE_CLIENT_ID=V1:your_username:your_password:EXT
SABRE_CLIENT_SECRET=your_sabre_client_secret
SABRE_TOKEN_URL=https://api.sabre.com/v2/auth/token
SABRE_BASE_URL=https://api.sabre.com
SABRE_PCC=your_pcc

# ── Wallet service ─────────────────────────────────────────────────────────────
# Free API key: https://www.exchangerate-api.com (sign up → copy key)
# 1,500 req/month on free tier; cached 15 min in Redis so ~3/hr used in practice
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# ── Push notifications (PWA) ───────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:push@utubooking.com
INTERNAL_API_SECRET=your-internal-secret-minimum-32-chars
FRONTEND_URL=http://frontend:3000

# ── Service ports ──────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
HOTEL_SERVICE_PORT=3003
FLIGHT_SERVICE_PORT=3004
CAR_SERVICE_PORT=3005
BOOKING_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
WALLET_SERVICE_PORT=3010
PRICING_SERVICE_PORT=3011

# ── Pricing service (AI Revenue Optimization) ──────────────────────────────
# ANTHROPIC_API_KEY: get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
# Default room capacity per hotel — used for occupancy % calculation in demand forecasting
HOTEL_CAPACITY=50
# Internal URL of pricing service — used by Lambda cron
PRICING_SERVICE_URL=http://pricing-service:3011

# Get free sandbox key at: developer.hotelbeds.com

# ── GDPR Compliance (Phase EU) ─────────────────────────────────────────────────
# Required before any European user can register.
# DPO = Data Protection Officer; EU_DATA_CONTROLLER = legal entity name shown in data exports.
DPO_EMAIL=dpo@utubooking.com
EU_DATA_CONTROLLER="UTUBooking Ltd, [Registered Address, UK/EU]"
# EU_REPRESENTATIVE: Required under Art. 27 GDPR if processing EU residents' data from outside EU.
# Appoint a representative in an EU member state if the company is UK-only post-Brexit.
EU_REPRESENTATIVE_EMAIL=eu-rep@utubooking.com

# ══════════════════════════════════════════════════════════════════════════════
# Phase 8 — Europe (provision RDS instances first, then replace placeholders)
# Stacks: infra/cloudformation/16-eu-west-2-london.yml
#         infra/cloudformation/17-eu-central-1-frankfurt.yml
# Deploy: aws cloudformation deploy --region eu-west-2 --template-file 16-eu-west-2-london.yml
#         aws cloudformation deploy --region eu-central-1 --template-file 17-eu-central-1-frankfurt.yml
# ══════════════════════════════════════════════════════════════════════════════

# UK — eu-west-2 London (UK GDPR data sovereignty)
# Serves: GB
DATABASE_URL_LONDON=postgresql://utu_user:CHANGE_ME@[RDS-eu-west-2-endpoint]:5432/utu_booking
READ_DB_URL_LONDON=postgresql://utu_user:CHANGE_ME@[RDS-eu-west-2-replica]:5432/utu_booking

# EU Mainland — eu-central-1 Frankfurt (GDPR Art. 44 — within EU)
# Serves: DE, FR, NL, ES, IT, BE, PL, BA, CH, AT, SE, DK, FI, NO, PT, IE, GR + TR (KVKK)
DATABASE_URL_FRANKFURT=postgresql://utu_user:CHANGE_ME@[RDS-eu-central-1-endpoint]:5432/utu_booking
READ_DB_URL_FRANKFURT=postgresql://utu_user:CHANGE_ME@[RDS-eu-central-1-replica]:5432/utu_booking

# ══════════════════════════════════════════════════════════════════════════════
# Phase 10 — North America
# Stacks: infra/cloudformation/18-us-east-1-virginia.yml
#         infra/cloudformation/20-ca-central-1-montreal.yml
# ══════════════════════════════════════════════════════════════════════════════

# USA — us-east-1 Virginia
# Serves: US
DATABASE_URL_US_EAST=postgresql://utu_user:CHANGE_ME@[RDS-us-east-1-endpoint]:5432/utu_booking
DB_URL_US_EAST=postgresql://utu_user:CHANGE_ME@[RDS-us-east-1-endpoint]:5432/utu_booking
READ_DB_URL_US_EAST=postgresql://utu_user:CHANGE_ME@[RDS-us-east-1-replica]:5432/utu_booking

# Canada — ca-central-1 Montreal (PIPEDA compliance)
# Serves: CA
DATABASE_URL_MONTREAL=postgresql://utu_user:CHANGE_ME@[RDS-ca-central-1-endpoint]:5432/utu_booking
READ_DB_URL_MONTREAL=postgresql://utu_user:CHANGE_ME@[RDS-ca-central-1-replica]:5432/utu_booking

# ══════════════════════════════════════════════════════════════════════════════
# Phase 12 — South America
# Stack: infra/cloudformation/19-sa-east-1-sao-paulo.yml
# ══════════════════════════════════════════════════════════════════════════════

# Brazil + LATAM — sa-east-1 São Paulo (LGPD data localisation)
# Serves: BR, AR, CO, CL, PE, UY
DATABASE_URL_SAO_PAULO=postgresql://utu_user:CHANGE_ME@[RDS-sa-east-1-endpoint]:5432/utu_booking
READ_DB_URL_SAO_PAULO=postgresql://utu_user:CHANGE_ME@[RDS-sa-east-1-replica]:5432/utu_booking

# ── Singapore (Phase 7 — already provisioned, add if missing) ─────────────────
# Serves: ID, MY, SG, TH, PH
DATABASE_URL_SINGAPORE=postgresql://utu_user:CHANGE_ME@[RDS-ap-southeast-1-endpoint]:5432/utu_booking
READ_DB_URL_SINGAPORE=postgresql://utu_user:CHANGE_ME@[RDS-ap-southeast-1-replica]:5432/utu_booking

# ══════════════════════════════════════════════════════════════════════════════
# Route53 Stack 09 — SSM Parameter Store paths
# After deploying stacks 16-20, push ALB DNS values to SSM so the Route53
# stack can resolve them at deploy time via AWS::SSM::Parameter::Value<String>.
#
# Run once per region (replace <ALB_DNS> and <ALB_HZ> with CF stack outputs):
#   aws ssm put-parameter --name /utu/london/alb-dns        --value <ALB_DNS> --type String --region us-east-1
#   aws ssm put-parameter --name /utu/london/alb-hosted-zone --value <ALB_HZ>  --type String --region us-east-1
#   ... repeat for frankfurt, us-east, montreal, sao-paulo
#
# CloudFront domain (US only) — from stack 18 output UtuCFDistributionDomain:
#   aws ssm put-parameter --name /utu/us-east/cloudfront-dns --value <CF_DOMAIN> --type String --region us-east-1
# ══════════════════════════════════════════════════════════════════════════════

# SSM paths — these are the parameter *names*, not the values.
# Values are stored in SSM and injected by CloudFormation at deploy time.
# Documented here for ops reference:
#   /utu/london/alb-dns
#   /utu/london/alb-hosted-zone
#   /utu/frankfurt/alb-dns
#   /utu/frankfurt/alb-hosted-zone
#   /utu/us-east/alb-dns
#   /utu/us-east/alb-hosted-zone
#   /utu/us-east/cloudfront-dns
#   /utu/montreal/alb-dns
#   /utu/montreal/alb-hosted-zone
#   /utu/sao-paulo/alb-dns
#   /utu/sao-paulo/alb-hosted-zone

# ══════════════════════════════════════════════════════════════════════════════
# Phase 8-9 — European Payments
# ══════════════════════════════════════════════════════════════════════════════

# Stripe — enable these currencies in Stripe Dashboard:
#   EUR, GBP, PLN, SEK, NOK, DKK, CHF, CZK, HUF, RON
# Stripe Dashboard → Settings → Payment Methods → enable:
#   SEPA Direct Debit, iDEAL, Bancontact, BLIK, Klarna
#   Apple Pay + Google Pay (add EUR + GBP wallet configs)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ── TWINT (Switzerland) ───────────────────────────────────────────────────────
# Apply for partner access at: developer.twint.ch
# Complete merchant onboarding + KYC with TWINT AG before setting these.
# NOTE: npm install twint-integration does NOT exist — the gateway uses direct REST.
# Alternative: enable TWINT in Stripe Dashboard for CHF (no separate contract needed)
TWINT_ENVIRONMENT=test
TWINT_CLIENT_ID=CHANGE_ME
TWINT_CLIENT_SECRET=CHANGE_ME
TWINT_PARTNER_ID=CHANGE_ME
TWINT_WEBHOOK_SECRET=CHANGE_ME
TWINT_WEBHOOK_URL=https://api.utubooking.com/api/payments/twint/webhook

# ── PayPal (USA primary payment — Phase 10) ───────────────────────────────────
# 1. Create app at: https://developer.paypal.com/dashboard/applications
# 2. npm install @paypal/checkout-server-sdk
# 3. Set PAYPAL_ENV=live before go-live in US market
# 4. Register webhook at: developer.paypal.com → Apps → Webhooks
#    Events: PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED,
#            PAYMENT.CAPTURE.REFUNDED, CHECKOUT.ORDER.APPROVED
# 5. Copy Webhook ID into PAYPAL_WEBHOOK_ID
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_ENV=sandbox               # change to 'live' for US launch
PAYPAL_WEBHOOK_ID=CHANGE_ME      # from PayPal Developer Dashboard → Webhooks

# ── Affirm BNPL (USA — bookings ≥ $200, Phase 10) ────────────────────────────
# 1. Apply at: https://www.affirm.com/business
# 2. Get sandbox keys from: https://sandbox.affirm.com/dashboard
# 3. No npm package — gateway uses direct Affirm REST API v2 (see affirm.gateway.js)
# 4. Webhook endpoint: https://api.utubooking.com/api/payments/affirm/webhook
#    Register in Affirm Merchant Dashboard → Settings → Webhooks
#    Events: charge.confirmed, charge.captured, charge.voided, charge.rejected, charge.refunded
# 5. Set AFFIRM_ENV=production before US launch
AFFIRM_PUBLIC_KEY=CHANGE_ME      # from Affirm Merchant Dashboard → API Keys
AFFIRM_PRIVATE_KEY=CHANGE_ME     # keep secret — used for auth + webhook HMAC verification
AFFIRM_ENV=sandbox               # change to 'production' for US launch

# ── Bambora / Worldline Canada (Interac Online — Phase 13) ───────────────────
# 1. Sign up at: https://dev.na.bambora.com  (Worldline Canada portal)
# 2. Create merchant account → get Merchant ID + API Passcode
# 3. In Bambora portal: enable "Interac Online" payment method
# 4. Set Approved URL / Declined URL to your UTUBooking return endpoint
# 5. Webhook URL: https://api.utubooking.com/api/payments/interac/callback
# 6. Set BAMBORA_ENV=production before CA launch
BAMBORA_MERCHANT_ID=CHANGE_ME
BAMBORA_PASSCODE=CHANGE_ME
BAMBORA_ENV=sandbox

# ── Canada Privacy (PIPEDA + Quebec Law 25) ───────────────────────────────────
# CA_DATA_CONTROLLER: legal entity name for PIPEDA portability exports
# CA_PRIVACY_OFFICER: contact shown in privacy notices + breach notifications
CA_DATA_CONTROLLER="UTUBooking Canada Inc., [Registered Address, Canada]"
CA_PRIVACY_OFFICER_EMAIL=privacy@utubooking.com

# ── MercadoPago — LATAM (AR/CO/CL/UY/MX/PE — Phase 12) ──────────────────────
# 1. Create developer account at: https://www.mercadopago.com.br/developers
# 2. Create Application → get Access Token (sandbox first, then production)
# 3. Set notification_url in Preference to: https://api.utubooking.com/api/payments/mercadopago/webhook
# 4. Back URLs registered in preference body (not dashboard) — see mercadopago.gateway.js
# 5. Set MERCADOPAGO_ENV=production before LATAM launch
# Note: One Access Token covers all LATAM countries (multi-currency support built in)
MERCADOPAGO_ACCESS_TOKEN=CHANGE_ME   # TEST-xxx for sandbox; APP_USR-xxx for production
MERCADOPAGO_ENV=sandbox

# ── Brazil (Pix + Boleto — Phase 12) ─────────────────────────────────────────
# Pix + Boleto via Stripe Brazil — no extra credentials needed beyond STRIPE_SECRET_KEY.
# Enable in: Stripe Dashboard → Settings → Payment methods → Brazil → Pix + Boleto Bancário
# Stripe Brazil entity handles BRL settlements and BCB compliance automatically.

# ── Brazil Privacy (LGPD — Phase 12) ─────────────────────────────────────────
# BR_DATA_CONTROLLER: legal entity for LGPD data exports
# BR_DPO_EMAIL: Encarregado (DPO) contact — mandatory for large-scale processing (Art. 41)
BR_DATA_CONTROLLER="UTUBooking Brasil Ltda., [Endereço Registrado, Brasil]"
BR_DPO_EMAIL=privacidade@utubooking.com
# ANPD registration: anpd.gov.br → register as data controller before BR launch

# ── US Muslim Features (Phase 10) ────────────────────────────────────────────
# Google Places API — Halal Restaurant POI endpoint
# Enable "Places API" at: console.cloud.google.com → APIs & Services → Library
# Billing required (very low cost for typical usage — 1000 req/month ≈ $2)
GOOGLE_PLACES_API_KEY=CHANGE_ME

# Internal service URLs — used by Next.js API route proxies (server-side only)
# In Docker Compose / ECS: use service names (http://hotel-service:3003)
# In development: use localhost with ports
INTERNAL_HOTEL_SERVICE_URL=http://hotel-service:3003
INTERNAL_FLIGHT_SERVICE_URL=http://flight-service:3004
INTERNAL_AUTH_SERVICE_URL=http://auth-service:3001

# ── California Seller of Travel (Phase 10) ───────────────────────────────────
# Required by CA Business & Professions Code §17550.
# Register at: oag.ca.gov/travel (California Attorney General office)
# Replace with actual CST number once registration certificate is issued.
NEXT_PUBLIC_CA_CST_NUMBER=2000000-40

# ── WhatsApp Business Cloud API (Phase 12 — Brazil) ─────────────────────────
# Register at: developers.facebook.com → WhatsApp → Getting Started
# META_WHATSAPP_TOKEN: permanent system-user token from Meta Business Suite
#   Business Settings → System Users → Generate Token (whatsapp_business_messaging permission)
# WHATSAPP_PHONE_NUMBER_ID: numeric ID from WhatsApp → API Setup (not the display phone number)
# WHATSAPP_VERIFY_TOKEN: arbitrary string you choose — used for webhook URL verification
# META_WHATSAPP_APP_SECRET: App Secret from App Dashboard → Settings → Basic
#   Used to verify X-Hub-Signature-256 on inbound webhooks
META_WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_random_string
META_WHATSAPP_APP_SECRET=CHANGE_ME
