PORT=3012
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
READ_DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Shared secrets ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_me_strong_random_secret

# ── API Gateways (regional routing) ──────────────────────────────────────────
# Internal gateway host for SEA region (Singapore)
API_GATEWAY_HOST=http://localhost:3000

# Iran market — requires separate isolated gateway (Legal review required)
# See: backend/legal/iran/feasibility-brief.md
# IRAN_API_GATEWAY_HOST=          # do NOT configure without Legal Agent approval
