# Admin service uses ADMIN_PORT (not PORT) — default is 3012
ADMIN_PORT=3012
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
READ_DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Shared secrets (must match auth + frontend values) ───────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_me_strong_random_secret
