PORT=3013
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
READ_DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SALES_SECRET takes precedence; falls back to ADMIN_SECRET if unset
# SALES_SECRET=change_me_strong_random_secret
ADMIN_SECRET=change_me_strong_random_secret
