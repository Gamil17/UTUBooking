PORT=3004
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# Redis (flight search cache — 3-minute TTL)
REDIS_URL=redis://localhost:6379

# ── Amadeus GDS (primary) ──────────────────────────────────────────────────────
# Docs: https://developers.amadeus.com
# hostname: 'test' = sandbox, 'production' = live
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test

# ── Sabre GDS (fallback) ───────────────────────────────────────────────────────
# Docs: https://developer.sabre.com
# SABRE_CLIENT_ID format: 'V1:<username>:<password>:<domain>'
SABRE_CLIENT_ID=V1:your_username:your_password:EXT
SABRE_CLIENT_SECRET=your_sabre_client_secret
SABRE_TOKEN_URL=https://api.sabre.com/v2/auth/token
SABRE_BASE_URL=https://api.sabre.com
SABRE_PCC=your_pcc
