PORT=3001
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate both with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use TWO different values — do NOT reuse the same secret for both.
JWT_SECRET=change_me_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_token_secret_min_64_chars_different

# ── Email (password reset dispatch) ──────────────────────────────────────────
# Free tier: https://app.sendgrid.com → Settings → API Keys → Create (Mail Send scope)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@utubooking.com

# Frontend base URL — used to build the reset link in the email
FRONTEND_URL=http://localhost:3000

# ── Admin API secret ──────────────────────────────────────────────────────────
# Shared with Next.js frontend (ADMIN_SECRET) and all services that expose
# admin-auth-protected routes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_me_strong_random_secret
