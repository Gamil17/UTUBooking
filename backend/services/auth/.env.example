PORT=3001

# PostgreSQL
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# Redis
REDIS_URL=redis://localhost:6379

# JWT — use two DIFFERENT secrets; generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_token_secret_min_64_chars_different

NODE_ENV=development
