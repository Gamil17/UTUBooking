PORT=3005
NODE_ENV=development

# ── Redis (exchange rate cache) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CartTrawler (car rental aggregator) ──────────────────────────────────────
# Docs: https://www.cartrawler.com/ct/technology/api/
# Access: Contact your CartTrawler account manager for test credentials
CARTRAWLER_BASE_URL=https://ota.cartrawler.com/cartrawlerota/json
CARTRAWLER_CLIENT_ID=your_cartrawler_client_id
CARTRAWLER_CLIENT_SECRET=your_cartrawler_client_secret

# ── Exchange rates (currency conversion) ─────────────────────────────────────
# Free tier: https://www.exchangerate-api.com (1,500 req/month free)
EXCHANGERATE_API_KEY=your_exchangerate_api_key
