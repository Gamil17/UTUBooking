PORT=3002
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
READ_DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis (BullMQ job queue) ───────────────────────────────────────────────────
# Simple local Redis (no auth):
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_AUTH_TOKEN=          # required for managed Redis (Upstash, ElastiCache)
# REDIS_TLS=true             # set to 'true' for TLS-enabled Redis in prod

# ── SendGrid (transactional email) ────────────────────────────────────────────
# Free tier: https://app.sendgrid.com → Settings → API Keys → Create (Mail Send scope)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@utubooking.com
SENDGRID_FROM_NAME=UTUBooking
SENDGRID_REPLY_TO=support@utubooking.com
SENDGRID_WEBHOOK_SECRET=change_me_sendgrid_webhook_secret

# ── Internal service URLs (for cross-service calls) ───────────────────────────
INTERNAL_HOTEL_SERVICE_URL=http://localhost:3003
INTERNAL_FLIGHT_SERVICE_URL=http://localhost:3004
INTERNAL_CAR_SERVICE_URL=http://localhost:3005

# ── Shared secrets (must match across all services) ───────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_me_strong_random_secret
INTERNAL_API_SECRET=change_me_strong_random_secret

# ── Frontend base URL (used to build links in emails) ─────────────────────────
APP_URL=http://localhost:3000

# ── Notification service public URL (used for click-tracking redirect links in emails) ──
# In production set this to the public URL of the notification service, e.g.:
# NOTIFICATION_PUBLIC_URL=https://api.utubooking.com/n
NOTIFICATION_PUBLIC_URL=http://localhost:3002

# ── Internal notification service URL (used by admin-service for timeline fan-out) ──
# Default is http://localhost:3002 — no change needed for local dev
# NOTIFICATION_SERVICE_URL=http://localhost:3002
