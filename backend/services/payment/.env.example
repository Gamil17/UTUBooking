PORT=3007

# PostgreSQL
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── STC Pay Merchant API v2 ────────────────────────────────────────────────────
# Docs: backend/docs/stcpay-api.md  |  https://dev.stcpay.net
# Sandbox credentials: merchant ID usually starts with TEST_
STCPAY_BASE_URL=https://b2b.stcpay.com.sa/b2b/payment
STCPAY_API_KEY=your_stcpay_api_key
STCPAY_API_SECRET=your_stcpay_api_secret
STCPAY_MERCHANT_ID=TEST_your_merchant_id
STCPAY_SANDBOX_MODE=true
STCPAY_WEBHOOK_SECRET=your_stcpay_webhook_hmac_secret

# Where STC Pay POSTs payment results (must be HTTPS in production)
STCPAY_CALLBACK_URL=https://api.utubooking.com/api/payments/webhook

# ── Moyasar (Mada debit card) ─────────────────────────────────────────────────
# Docs: https://docs.moyasar.com
MOYASAR_API_KEY=sk_test_your_moyasar_key
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret
MOYASAR_CALLBACK_URL=https://api.utubooking.com/api/payments/mada/callback

# ── Stripe (Visa / Mastercard — international) ────────────────────────────────
# Docs: https://stripe.com/docs/api
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── iyzico (Turkey — TRY) ────────────────────────────────────────────────────
# Docs: https://dev.iyzipay.com  |  npm install iyzipay
# Sandbox: IYZICO_SANDBOX_MODE=true uses sandbox-api.iyzipay.com
IYZICO_API_KEY=sandbox-your_iyzico_api_key
IYZICO_SECRET_KEY=sandbox-your_iyzico_secret_key
IYZICO_SANDBOX_MODE=true
# Called by iyzico after 3DS — receives token in URL-encoded POST body
IYZICO_CALLBACK_URL=https://api.utubooking.com/api/payments/iyzico/callback

# ── Midtrans (Indonesia — IDR) ───────────────────────────────────────────────
# Docs: https://docs.midtrans.com  |  npm install midtrans-client
# Sandbox: MIDTRANS_SANDBOX_MODE=true; get keys from https://dashboard.sandbox.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-your_server_key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your_client_key
MIDTRANS_SANDBOX_MODE=true
# Midtrans sends JSON notification here (configure in Midtrans dashboard → Settings → Configuration)
MIDTRANS_NOTIFICATION_URL=https://api.utubooking.com/api/payments/midtrans/notification
MIDTRANS_FINISH_URL=https://utubooking.com/payment/success

# ── iPay88 (Malaysia — MYR) ──────────────────────────────────────────────────
# Docs: https://developer.ipay88.com.my
# No npm package — uses SHA256 form-POST redirect flow
IPAY88_MERCHANT_CODE=M00001           # assigned by iPay88 at merchant registration
IPAY88_MERCHANT_KEY=your_merchant_key # keep SECRET — used in signature computation
IPAY88_SANDBOX_MODE=true
# iPay88 POSTs URL-encoded form data to BackendURL (silent) and ResponseURL (browser)
IPAY88_RESPONSE_URL=https://api.utubooking.com/api/payments/ipay88/response
IPAY88_BACKEND_URL=https://api.utubooking.com/api/payments/ipay88/response

# ── JazzCash (Pakistan — PKR, primary) ───────────────────────────────────────
# Docs: https://sandbox.jazzcash.com.pk/ApplicationAPI
# Register at: https://jazzcash.com.pk/corporate/ → Merchant Onboarding
# Sandbox credentials from JazzCash Developer Portal
JAZZCASH_MERCHANT_ID=your_jazzcash_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_api_password
JAZZCASH_INTEGRITY_SALT=your_jazzcash_integrity_salt   # HMAC-SHA256 key — keep SECRET
JAZZCASH_SANDBOX_MODE=true
# JazzCash POSTs JSON callback here after customer confirms/declines in app
JAZZCASH_RETURN_URL=https://api.utubooking.com/api/payments/jazzcash/callback

# ── Easypaisa (Pakistan — PKR, secondary) ────────────────────────────────────
# Docs: https://developer.easypaisa.com.pk
# Register at: https://easypaisa.com.pk → Merchant Services
EASYPAISA_STORE_ID=your_easypaisa_store_id
EASYPAISA_ACCOUNT_NUMBER=your_easypaisa_merchant_account_11_digits
EASYPAISA_HASH_KEY=your_easypaisa_merchant_password    # SHA256 hash key — keep SECRET
EASYPAISA_SANDBOX_MODE=true
# Easypaisa POSTs form-encoded callback here after transaction
EASYPAISA_POSTBACK_URL=https://api.utubooking.com/api/payments/easypaisa/callback

# ── Razorpay (India + Bangladesh — INR) ──────────────────────────────────────
# Docs: https://razorpay.com/docs/api  |  npm install razorpay
# Test keys start with rzp_test_; live keys start with rzp_live_
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret     # keep SECRET — used for all HMAC operations
# Webhook secret: Dashboard → Webhooks → Create → set this as the secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_SANDBOX_MODE=true
# Razorpay POSTs JSON webhook to this URL (configure in Razorpay dashboard → Webhooks)
RAZORPAY_WEBHOOK_URL=https://api.utubooking.com/api/payments/razorpay/webhook

# ── South Asia Data Residency — AWS Mumbai (ap-south-1) ──────────────────────
# Required by India DPDP Act 2023 (§ 17 cross-border transfer restrictions)
# and Pakistan PECA 2016 for citizen data storage.
# Shared by IN + PK users (separate schemas within same RDS instance).
# Provision via: infra/cloudformation/ (add ap-south-1 stack)
DATABASE_URL_MUMBAI=postgresql://utu_user:password@[rds-mumbai-endpoint]:5432/utubooking_sa
READ_DATABASE_URL_MUMBAI=postgresql://utu_user:password@[rds-mumbai-read-endpoint]:5432/utubooking_sa
REDIS_URL_MUMBAI=redis://[elasticache-mumbai-endpoint]:6379
# Shard router env vars (used by backend/shared/shard-router.js)
DB_URL_MUMBAI=postgresql://utu_user:password@[rds-mumbai-endpoint]:5432/utubooking_sa
READ_DB_URL_MUMBAI=postgresql://utu_user:password@[rds-mumbai-read-endpoint]:5432/utubooking_sa

# ── Internal service authentication ──────────────────────────────────────────
# Shared secret for service-to-service calls (x-internal-secret header).
# Must match INTERNAL_API_SECRET in all other services.
INTERNAL_API_SECRET=your_internal_api_secret_min_32_chars

# ── Admin Service (port 3012) ─────────────────────────────────────────────────
ADMIN_PORT=3012
# ADMIN_SECRET is shared with all services that expose admin-auth-protected routes

# ── Phase 7 — SEA Region (Singapore ap-southeast-1) ──────────────────────────
# Indonesia (PDP) + Malaysia (PDPA) — provision via infra/cloudformation/
DB_URL_SEA=postgresql://utu_user:password@[rds-singapore-endpoint]:5432/utubooking_sea
READ_DB_URL_SEA=postgresql://utu_user:password@[rds-singapore-read-endpoint]:5432/utubooking_sea

# ── Phase 7 — Grafana Route53 Health Check IDs (for multi-region dashboard) ──
# Get these from the CloudFormation stack outputs after deploying 09-route53-global.yml
HEALTH_CHECK_BAHRAIN_ID=           # Route53 health check ID for Bahrain ALB
HEALTH_CHECK_EU_ID=                # Route53 health check ID for Frankfurt ALB
HEALTH_CHECK_SEA_ID=               # Route53 health check ID for Singapore ALB
HEALTH_CHECK_MUMBAI_ID=            # Route53 health check ID for Mumbai ALB

# ── Haj Committee of India (HCoI) — Partner API ───────────────────────────────
# Apply for partner credentials: https://minorityaffairs.gov.in (IT portal)
# Contact: it@hajcommittee.gov.in — submit company registration + DPO details + DPA
# Adapter: backend/adapters/hajj/hajCommitteeIndia.ts
# Visibility: country=IN + booking type=Hajj only
HCOI_API_KEY=your_hcoi_partner_api_key          # issued by HCoI IT division
HCOI_PARTNER_ID=UTU-BOOKING-001                 # UTUBooking registered partner ID
HCOI_PARTNER_SECRET=your_hcoi_hmac_secret       # HMAC-SHA256 signing secret — keep SECRET
HCOI_SANDBOX=true                               # 'false' for production

# ── TWINT (Switzerland — CHF) ────────────────────────────────────────────────
# Docs: https://www.twint.ch/en/business/twint-partner-api/
# Register: TWINT AG partner portal — requires CH business registration
# Sandbox: TWINT_ENVIRONMENT=TESTING uses sandbox.twint.ch
TWINT_CLIENT_ID=your_twint_client_id
TWINT_CLIENT_SECRET=your_twint_client_secret
TWINT_PARTNER_ID=your_twint_partner_id
TWINT_ENVIRONMENT=TESTING                                  # TESTING | PRODUCTION
TWINT_WEBHOOK_SECRET=your_twint_webhook_secret
# TWINT POSTs JSON payment result notification here
TWINT_WEBHOOK_URL=https://api.utubooking.com/api/payments/twint/webhook

# ── PayPal (United States — USD, secondary) ──────────────────────────────────
# Docs: https://developer.paypal.com/api/rest/
# Register: https://developer.paypal.com → Create App in sandbox
# Sandbox: PAYPAL_ENV=sandbox uses sandbox.paypal.com — no real money
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_secret
PAYPAL_ENV=sandbox                                         # sandbox | live
# Webhook ID: PayPal Developer Dashboard → Webhooks → Add webhook
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
# PayPal redirects here after authorization
PAYPAL_CALLBACK_URL=https://api.utubooking.com/api/payments/paypal/callback

# ── Affirm BNPL (United States — USD, bookings ≥ $200) ───────────────────────
# Docs: https://docs.affirm.com/affirm-developers/reference
# Register: https://developer.affirm.com → request sandbox credentials
# Sandbox: AFFIRM_ENV=sandbox uses sandbox.affirm.com
AFFIRM_PUBLIC_KEY=your_affirm_sandbox_public_key
AFFIRM_PRIVATE_KEY=your_affirm_sandbox_private_key
AFFIRM_ENV=sandbox                                         # sandbox | production
# Affirm redirects here after checkout
AFFIRM_CONFIRM_URL=https://api.utubooking.com/api/payments/affirm/confirm
AFFIRM_CANCEL_URL=https://utubooking.com/checkout

# ── Bambora / Interac Online (Canada — CAD) ───────────────────────────────────
# Docs: https://dev.na.bambora.com/docs/
# Register: https://dev.na.bambora.com → Create test account
# Bambora is Interac Online's preferred aggregator for CA market
BAMBORA_MERCHANT_ID=your_bambora_merchant_id
BAMBORA_PASSCODE=your_bambora_api_passcode
BAMBORA_ENV=sandbox                                        # sandbox | production
# Bambora POSTs callback here after payment
BAMBORA_CALLBACK_URL=https://api.utubooking.com/api/payments/bambora/callback

# ── MercadoPago (Brazil + LatAm — BRL/USD) ───────────────────────────────────
# Docs: https://www.mercadopago.com.br/developers/en/reference
# Register: https://www.mercadopago.com.br/developers/en/devpanel → Create test users
# Sandbox: access token starts with TEST-
MERCADOPAGO_ACCESS_TOKEN=TEST-your_access_token
MERCADOPAGO_ENV=sandbox                                    # sandbox | production
# MercadoPago POSTs IPN (Instant Payment Notification) here
MERCADOPAGO_NOTIFICATION_URL=https://api.utubooking.com/api/payments/mercadopago/notification

NODE_ENV=development
