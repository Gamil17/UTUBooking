PORT=3006
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT secret (access token verification) ───────────────────────────────────
# Must match JWT_SECRET in the auth service — bookings service verifies tokens
# but does NOT issue them.
JWT_SECRET=change_me_must_match_auth_service_jwt_secret

# ── Internal service secrets ──────────────────────────────────────────────────
# Shared with auth service and Next.js BFF for service-to-service calls.
ADMIN_SECRET=change_me_must_match_auth_service_admin_secret

# ── Auth service base URL ─────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
