PORT=3010
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking
READ_DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_CLUSTER_URLS=redis://node1:6379,redis://node2:6379  # for Redis Cluster (prod)
# REDIS_AUTH_TOKEN=                                          # for managed Redis

# ── JWT (must match auth service value) ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_access_token_secret_min_64_chars

# ── Exchange rates ─────────────────────────────────────────────────────────────
# Free tier (1,500 req/month): https://app.exchangerate-api.com/sign-up
# Used for UTU Rewards points → currency conversion
EXCHANGERATE_API_KEY=your_exchangerate_api_key
