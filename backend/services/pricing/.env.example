PORT=3011
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# ElastiCache cluster mode (production only):
# REDIS_CLUSTER_URLS=rediss://node-1:6379,rediss://node-2:6379
# REDIS_AUTH_TOKEN=your_auth_token

# ── JWT (access token verification) ──────────────────────────────────────────
# Must match JWT_SECRET in auth service — pricing service verifies tokens
# but does NOT issue them.
JWT_SECRET=change_me_must_match_auth_service_jwt_secret

# ── Internal service secrets ──────────────────────────────────────────────────
# Shared with auth service and Next.js BFF.
ADMIN_SECRET=change_me_must_match_auth_service_admin_secret
INTERNAL_API_SECRET=change_me_must_match_shared_internal_secret

# ── Anthropic (Claude AI demand forecasting) ──────────────────────────────────
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Pricing config ────────────────────────────────────────────────────────────
HOTEL_CAPACITY=50          # default max rooms per hotel for demand calculation
FRONTEND_URL=http://localhost:3000   # used for demand push alert links
