PORT=3003
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Hotelbeds (primary — GCC / Makkah / Madinah) ─────────────────────────────
# Docs: https://developer.hotelbeds.com/documentation/hotels/
# Register: https://developer.hotelbeds.com → Create account → Test environment
# Sandbox: HOTELBEDS_ENV=test uses test.api.hotelbeds.com (no real charges)
HOTELBEDS_API_KEY=your_hotelbeds_api_key
HOTELBEDS_SECRET=your_hotelbeds_secret
HOTELBEDS_ENV=test                                         # test | production

# ── Booking.com B2B Affiliate API (EU / UK markets — Phase 8) ────────────────
# Docs: https://developers.booking.com/affiliateapi/
# Register: https://www.booking.com/affiliate-program/v2/signup.html
# Test environment uses the same credentials — set BOOKINGCOM_ENV=test
BOOKINGCOM_USERNAME=your_bookingcom_affiliate_username
BOOKINGCOM_PASSWORD=your_bookingcom_affiliate_password
BOOKINGCOM_ENV=test                                        # test | production
