# UTUBooking — Backend Environment Variables
# Copy to backend/.env and fill in your values.
# NEVER commit the real .env file.
#
# Required vars are marked (required).
# Optional vars have defaults or only apply to specific markets.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Primary read-write connection (required)
DATABASE_URL=postgresql://utu_user:password@localhost:5432/utu_booking

# Read replica — used by analytics/reporting queries (optional, defaults to DATABASE_URL)
READ_DATABASE_URL=postgresql://utu_user:password@localhost:5432/utu_booking

# ── Redis ─────────────────────────────────────────────────────────────────────
# Single-node for local dev (required)
REDIS_URL=redis://localhost:6379

# ElastiCache cluster mode (production — comma-separated)
# REDIS_CLUSTER_URLS=rediss://cluster-node-1:6379,rediss://cluster-node-2:6379
# REDIS_AUTH_TOKEN=your-auth-token

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_random_64_bytes            # (required)
JWT_REFRESH_SECRET=change_me_generate_random_64_bytes    # (required)

# Shared secret for service-to-service calls (PDF route → booking service, etc.)
ADMIN_SECRET=change_me_strong_random_secret              # (required)

# Shared secret for internal Lambda cron → pricing service push
INTERNAL_API_SECRET=change_me_strong_random_secret       # (required)

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                             # (required — AI chat + pricing)

# ── Hotel adapters ────────────────────────────────────────────────────────────
# Hotelbeds (primary — GCC/Makkah/Madinah)
HOTELBEDS_API_KEY=your_hotelbeds_api_key                 # (required for hotel search)
HOTELBEDS_SECRET=your_hotelbeds_secret
HOTELBEDS_ENV=test                                       # test | production

# Booking.com B2B (Phase 8 — EU/UK markets)
BOOKINGCOM_USERNAME=your_bookingcom_username              # (optional — EU only)
BOOKINGCOM_PASSWORD=your_bookingcom_password
BOOKINGCOM_ENV=test                                      # test | production

# ── Flight adapters ───────────────────────────────────────────────────────────
# Amadeus (primary GDS)
AMADEUS_CLIENT_ID=your_amadeus_client_id                 # (required for flight search)
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_ENV=test                                         # test | production

# Sabre (failover GDS)
SABRE_CLIENT_ID=your_sabre_client_id                     # (optional — failover)
SABRE_CLIENT_SECRET=your_sabre_client_secret

# ── Car rental adapters ───────────────────────────────────────────────────────
CARTRAWLER_BASE_URL=https://ota.cartrawler.com/cartrawlerota/json
CARTRAWLER_CLIENT_ID=your_cartrawler_client_id           # (required for car search)
CARTRAWLER_CLIENT_SECRET=your_cartrawler_secret

# ── Payment gateways ──────────────────────────────────────────────────────────

# Moyasar — Saudi Arabia (primary KSA gateway)
MOYASAR_API_KEY=sk_test_...                              # (required — KSA)
MOYASAR_CALLBACK_URL=https://utubooking.com/api/payments/moyasar/callback
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret

# Stripe — EU, US, UK, CA, AU
STRIPE_SECRET_KEY=sk_test_...                            # (required — EU/US markets)
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — US secondary
PAYPAL_CLIENT_ID=your_paypal_client_id                   # (optional — US)
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox                                       # sandbox | live
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Affirm BNPL — US (bookings ≥ $200)
AFFIRM_PUBLIC_KEY=your_affirm_public_key                 # (optional — US)
AFFIRM_PRIVATE_KEY=your_affirm_private_key
AFFIRM_ENV=sandbox                                       # sandbox | production

# Midtrans — Indonesia
MIDTRANS_SERVER_KEY=SB-Mid-server-...                    # (optional — ID)
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_SANDBOX_MODE=true
MIDTRANS_FINISH_URL=https://utubooking.com/checkout/confirm

# iyzico — Turkey
IYZICO_API_KEY=your_iyzico_api_key                       # (optional — TR)
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_SANDBOX_MODE=true
IYZICO_CALLBACK_URL=https://utubooking.com/api/payments/iyzico/callback

# iPay88 — Malaysia
IPAY88_MERCHANT_CODE=your_merchant_code                  # (optional — MY)
IPAY88_MERCHANT_KEY=your_merchant_key

# TWINT — Switzerland
TWINT_CLIENT_ID=your_twint_client_id                     # (optional — CH)
TWINT_CLIENT_SECRET=your_twint_client_secret
TWINT_PARTNER_ID=your_twint_partner_id
TWINT_ENVIRONMENT=TESTING                                # TESTING | PRODUCTION
TWINT_WEBHOOK_SECRET=your_twint_webhook_secret
TWINT_WEBHOOK_URL=https://utubooking.com/api/payments/twint/webhook

# Razorpay — India
RAZORPAY_KEY_ID=rzp_test_...                             # (optional — IN)
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# MercadoPago — Brazil / LatAm
MERCADOPAGO_ACCESS_TOKEN=TEST-...                        # (optional — BR/LATAM)
MERCADOPAGO_ENV=sandbox                                  # sandbox | production

# JazzCash — Pakistan
JAZZCASH_MERCHANT_ID=your_merchant_id                    # (optional — PK)
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_salt
JAZZCASH_RETURN_URL=https://utubooking.com/api/payments/jazzcash/callback
JAZZCASH_SANDBOX_MODE=true

# Easypaisa — Pakistan
EASYPAISA_STORE_ID=your_store_id                         # (optional — PK)
EASYPAISA_ACCOUNT_NUMBER=your_account_number
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_POSTBACK_URL=https://utubooking.com/api/payments/easypaisa/postback
EASYPAISA_SANDBOX_MODE=true

# Bambora — Canada
BAMBORA_MERCHANT_ID=your_bambora_merchant_id             # (optional — CA)
BAMBORA_PASSCODE=your_bambora_passcode
BAMBORA_ENV=sandbox

# STC Pay — Saudi Arabia (secondary)
STCPAY_MERCHANT_ID=your_stcpay_merchant_id               # (optional — KSA secondary)
STCPAY_API_KEY=your_stcpay_api_key
STCPAY_API_SECRET=your_stcpay_api_secret
STCPAY_BASE_URL=https://sandbox.stcpay.com.sa
STCPAY_CALLBACK_URL=https://utubooking.com/api/payments/stcpay/callback
STCPAY_WEBHOOK_SECRET=your_stcpay_webhook_secret

# ── Exchange rates ────────────────────────────────────────────────────────────
EXCHANGERATE_API_KEY=your_exchangerate_api_key           # (required — currency conversion)

# ── Push notifications (VAPID) ────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key                   # (required — PWA push)
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:push@utubooking.com

# ── WhatsApp Business API (Meta) ──────────────────────────────────────────────
META_WHATSAPP_ACCESS_TOKEN=your_access_token             # (optional — WhatsApp notifications)
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ── Tabung Haji API — Malaysia ────────────────────────────────────────────────
TH_API_KEY=your_th_api_key                               # (optional — MY Hajj)
TH_PARTNER_ID=your_th_partner_id
TH_PARTNER_SECRET=your_th_partner_secret
TH_SANDBOX=true
TH_SERVICE_URL=https://sandbox-api.tabunghaji.gov.my

# ── Pricing service (AI demand engine) ───────────────────────────────────────
HOTEL_CAPACITY=50                                        # default rooms per hotel
FRONTEND_URL=http://localhost:3000                        # for demand push alerts

# ── Data residency / Compliance ───────────────────────────────────────────────
# Shard pool URLs per region (see backend/shared/shard-router.js)
# DB_URL_SEA=postgresql://utu_user:password@sea-postgres:5432/utu_booking
# DB_URL_EU=postgresql://utu_user:password@eu-postgres:5432/utu_booking
# DB_URL_US=postgresql://utu_user:password@us-postgres:5432/utu_booking
# DB_URL_BR=postgresql://utu_user:password@br-postgres:5432/utu_booking

# DPO contacts (GDPR/LGPD requirement for production)
DPO_EMAIL=dpo@utubooking.com
EU_DATA_CONTROLLER=AMEC Solutions GmbH
BR_DATA_CONTROLLER=AMEC Solutions Ltda
BR_DPO_EMAIL=lgpd@utubooking.com
CA_DATA_CONTROLLER=AMEC Solutions Inc
CA_PRIVACY_OFFICER_EMAIL=privacy@utubooking.com


# ── Notification service (email automation) ───────────────────────────────────
NOTIFICATION_PORT=3002

# SendGrid — transactional + marketing email delivery
SENDGRID_API_KEY=SG.xxxx                                  # (required) from SendGrid dashboard
SENDGRID_FROM_EMAIL=noreply@utubooking.com                 # (required) verified sender identity
SENDGRID_FROM_NAME=UTUBooking                              # display name in From header
SENDGRID_REPLY_TO=support@utubooking.com                   # (optional) reply-to address
SENDGRID_WEBHOOK_SECRET=whsec_xxxx                        # (required) from SendGrid event webhook settings

# Internal service URLs (used by price-change alert processor to fetch current prices)
INTERNAL_HOTEL_SERVICE_URL=http://hotel-service:3003
INTERNAL_FLIGHT_SERVICE_URL=http://flight-service:3004
INTERNAL_CAR_SERVICE_URL=http://car-service:3005
